# ============================================================================
# IBM Daily Email Digest — environment secrets
# Copy this file to ".env" and fill in real values.  .env is git-ignored.
# ============================================================================

# ----- ICA (IBM Consulting Advantage) / LLM summarization --------------------
ICA_API_KEY=your-ica-api-key-here
ICA_CHAT_URL=https://api.nextgen-beta.ica.ibm.com/ica/v1/chat-models/chat/completions
ICA_MODEL=claude-haiku-4-5
ICA_AUTH_SCHEME=Bearer

# ----- Email delivery method -------------------------------------------------
# "sendgrid" -> SendGrid HTTPS API (headless; used for the IBM Cloud deployment)
# "smtp"     -> Gmail/Office365 SMTP (personal accounts)
# "outlook"  -> local Outlook desktop app (Windows only; needs Outlook open)
# (This overrides email.method in config/settings.yaml.)
EMAIL_METHOD=sendgrid

EMAIL_FROM=your-verified-sender@example.com       # must be verified in SendGrid

# ----- SendGrid (used when EMAIL_METHOD=sendgrid) ----------------------------
# API key: SendGrid > Settings > API Keys (Mail Send scope).
SENDGRID_API_KEY=your-sendgrid-api-key

# ----- SMTP (used when EMAIL_METHOD=smtp) ------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# ----- Per-team recipients (each newsletter -> its own group) ---------------
# Comma-separate. On GitHub, set these as repository secrets instead.
RECIPIENTS_NB_IRVING=person1@ibm.com,person2@ibm.com
RECIPIENTS_LCBO_LOBLAWS=person1@ibm.com,person2@ibm.com
RECIPIENTS_NL_NS_EMERA=person1@ibm.com,person2@ibm.com
RECIPIENTS_INTERAC_SYMCOR_PAYMENTS=person1@ibm.com,person2@ibm.com
RECIPIENTS_GFL_CBS_GTAA=person1@ibm.com,person2@ibm.com

# ----- Recipient override (optional): if set, ALL teams send only here.
# Leave unset for per-account routing from config/teams.yaml.
ONLY_TO=
